---
import Navigation from '../../components/Navigation.astro';
import "../../styles/global.css";

const pageTitle = "Art Page";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} >
    <title>Astro</title>
  </head>
 
  <body>
    <Navigation />
    <h1>This is where my sketches can be found</h1>
    <main class="max-w-6xl mx-auto px-6 py-12">

        <br>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    
    <!-- === ADD NEW PIECES HERE === -->
    <a href="/superduperwebsite/art/win7wp" class="group block overflow-hidden rounded-xl bg-zinc-900 hover:ring-2 hover:ring-zinc-400 transition-all">
      <img 
        src="/superduperwebsite/src/assets/art/win7wp.jpg" 
        alt="Windows 7 style wallpaper recreation"
        class="w-full aspect-[4/3] object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
      <div class="p-4">
        <h3 class="font-medium text-lg">Windows 7 Wallpaper</h3>
        <p class="text-sm text-zinc-400">Digital • 2025</p>
      </div>
    </a>

    <!-- Copy the block above for each new piece -->
    <!-- <a href="..." class="..."> ... </a> -->

  </div>
</main>
  </body>
</html>