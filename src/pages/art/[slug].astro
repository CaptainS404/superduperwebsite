---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Navigation from '../../components/Navigation.astro';
import "../../styles/global.css";

export async function getStaticPaths() {
  const artworks = await getCollection('artwork');
  return artworks.map(piece => ({
    params: { slug: piece.id }
  }));
}

const { slug } = Astro.params;
const piece = await getEntry('artwork', slug);

if (!piece) return Astro.redirect('/superduperwebsite/artpage');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{piece.data.title} | My Art</title>
  </head>
  <body>
    <Navigation />
    <main class="max-w-4xl mx-auto px-6 py-12">
      <a href="/superduperwebsite/artpage" class="text-sm mb-8 inline-block hover:underline">← Back to Gallery</a>
      
   <Image 
  src={`/src/assets/art/${slug}.jpg`}
  alt={piece.data.alt}
  width={1200}
  height={800}
  class="w-full rounded-2xl shadow-2xl"
/>
      
      <h1 class="text-4xl font-bold mt-10">{piece.data.title}</h1>
      {piece.data.medium && <p class="text-zinc-400 mt-2">{piece.data.medium}</p>}
      
      {piece.body && <div class="prose mt-8" set:html={piece.body} />}
    </main>
  </body>
</html>